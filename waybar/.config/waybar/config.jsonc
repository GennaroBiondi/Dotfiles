{
  "layer": "top",
  "position": "top",
  "margin-left": 4,
  "margin-right": 4,
  "margin-top": 4,
  "margin-bottom": 0,
  "spacing": 1,
  "reload_style_on_change": true,

  // Choose the order of the modules

  "modules-left": [
    "wireplumber",
  ],

  "modules-center": [
    "clock",
  ],

  "modules-right": [
      "mpris",
  ],

  "group/custom-group": {
    "orientation": "horizontal",
    "modules": ["tray", "idle_inhibitor", "custom/power"],
  },

  "tray": {
    "icon-size": 16,
    "spacing": 10,
    "show-passive-items": true,
    "reverse-direction": true,
  },

  "clock": {
    "interval": 60,
    "format": "{:%I:%M}", // %b %d %Y  ΎΡ║--Date formatting
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "ΎΒ│ {:%a %b %d}",
  },

