  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%", //{format_source}",
    "format-bluetooth": "{icon} {volume}% ≤░Γψ", //{format_source}",
    "format-bluetooth-muted": "≤░ΨΒ {icon} ≤░Γψ", //{format_source}",
    "format-muted": "≤░ΨΒ {volume}%",
    // "format-source": "ΎΕ░ {volume}%",
    // "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "≤░ΜΜ",
      "hands-free": "≤▒κΤ",
      "headset": "≤░ΜΟ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
    },
    "on-click": "pavucontrol",
  },

  "wireplumber": {
    "format": "{icon} {volume:>3}%",
    "format-muted": "≤░ΨΒ {volume:>3}%",
    "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
  },

